SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8090

DB_URL=jdbc:postgresql://localhost:5432/authservice
DB_USER=postgres
DB_PASS=postgres

JWT_SECRET=change-me-change-me-change-me-change-me
JWT_EXPIRATION_MS=3600000
JWT_ISSUER=authservice-api

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:5173/auth/callback
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:5173/login

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_BASE_BACKOFF_MS=1000
OUTBOX_EXCHANGE=auth.events
OUTBOX_ROUTING_KEY=user.registered.v1
