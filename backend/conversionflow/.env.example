##############################
# Perfil e servidor
##############################
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

##############################
# Banco de dados
##############################
DB_URL=jdbc:postgresql://localhost:5432/conversionflow
DB_USER=postgres
DB_PASS=admin
JPA_SHOW_SQL=true

##############################
# Stripe (obrigatório em produção)
##############################
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Importante:
# inclua session_id para o frontend enviar no pixel-event fallback.
CHECKOUT_SUCCESS_URL=http://localhost:3000/sucesso?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:3000/cancelado
STRIPE_CURRENCY=usd

# Price IDs do Stripe
STRIPE_PRICE_INCORPORATION_BASIC=price_xxx
STRIPE_PRICE_INCORPORATION_PREMIUM=price_xxx
STRIPE_PRICE_ACCOUNTING_MONTHLY=price_xxx

##############################
# Integrações
##############################
META_ACCESS_TOKEN=
META_PIXEL_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=
PIPEDRIVE_API_TOKEN=

##############################
# Dispatch retry policy
##############################
DISPATCH_RETRY_MAX_ATTEMPTS=5
DISPATCH_RETRY_INTERVAL_MS=60000

##############################
# Async auth events (RabbitMQ)
##############################
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
ASYNC_AUTH_EXCHANGE=auth.events
ASYNC_AUTH_USER_REGISTERED_QUEUE=auth.user.registered.v1
ASYNC_AUTH_USER_REGISTERED_ROUTING_KEY=user.registered.v1
ASYNC_AUTH_USER_REGISTERED_RETRY_QUEUE=auth.user.registered.v1.retry
ASYNC_AUTH_USER_REGISTERED_DLQ=auth.user.registered.v1.dlq
ASYNC_AUTH_RETRY_DELAY_MS=30000

##############################
# Segurança de admin (opcional)
##############################
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin123
