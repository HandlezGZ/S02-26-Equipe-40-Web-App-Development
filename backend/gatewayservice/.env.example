SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8070

AUTHSERVICE_BASE_URL=http://localhost:8090
CONVERSIONFLOW_BASE_URL=http://localhost:8080

GATEWAY_ROUTE_AUTH_API_ENABLED=true
GATEWAY_ROUTE_AUTH_OAUTH_ENABLED=true
GATEWAY_ROUTE_CONVERSIONFLOW_API_ENABLED=true

GATEWAY_DEFAULT_CONNECT_TIMEOUT_MS=1000
GATEWAY_DEFAULT_RESPONSE_TIMEOUT_MS=4000ms
GATEWAY_AUTH_CONNECT_TIMEOUT_MS=1000
GATEWAY_AUTH_RESPONSE_TIMEOUT_MS=3000
GATEWAY_CONVERSIONFLOW_CONNECT_TIMEOUT_MS=1000
GATEWAY_CONVERSIONFLOW_RESPONSE_TIMEOUT_MS=4000
GATEWAY_CONVERSIONFLOW_RETRY_ATTEMPTS=1

GATEWAY_ADMIN_USER=gateway-admin
GATEWAY_ADMIN_PASS=change-me

AUTH_JWT_SECRET=change-me-change-me-change-me-change-me
AUTH_JWT_ISSUER=authservice-api
AUTH_JWT_AUDIENCE=

GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REQUESTS_PER_WINDOW=60
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_RATE_LIMIT_TIMEOUT_MS=0

GATEWAY_AUTH_CB_WINDOW_SIZE=10
GATEWAY_AUTH_CB_MIN_CALLS=5
GATEWAY_AUTH_CB_HALF_OPEN_CALLS=3
GATEWAY_AUTH_CB_OPEN_MS=30000
GATEWAY_AUTH_CB_FAILURE_RATE=50

GATEWAY_CONVERSIONFLOW_CB_WINDOW_SIZE=10
GATEWAY_CONVERSIONFLOW_CB_MIN_CALLS=5
GATEWAY_CONVERSIONFLOW_CB_HALF_OPEN_CALLS=3
GATEWAY_CONVERSIONFLOW_CB_OPEN_MS=30000
GATEWAY_CONVERSIONFLOW_CB_FAILURE_RATE=50
